{
  "manifest_version": 3,
  "name": "Tuya Desk",
  "description": "Compact Chrome extension to control Tuya light switches by channel.",
  "version": "0.1.0",
  "permissions": ["storage"],
  "host_permissions": ["https://*/*"],
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "action": {
    "default_title": "Tuya Desk",
    "default_popup": "popup.html"
  }
}
